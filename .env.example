# ── Madex ERP — Variáveis de ambiente ────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores obrigatórios.
#   cp .env.example .env
#
# Variáveis marcadas com  ★ OBRIGATÓRIO  devem ser definidas antes de subir.
# As demais possuem valores padrão funcionais para desenvolvimento/homologação.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────

# ★ OBRIGATÓRIO — senha do PostgreSQL
DB_PASSWORD=troque_essa_senha

# Nome do banco e usuário (padrão já funciona com o docker-compose)
DB_NAME=madeireira
DB_USER=postgres

# Usado apenas fora do docker-compose (acesso direto ao banco externo)
# DB_URL=jdbc:postgresql://host:5432/madeireira

# URL no formato Railway/Render (sobrepõe DB_URL + DB_USER + DB_PASSWORD)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Autenticação JWT ──────────────────────────────────────────────────────────

# ★ OBRIGATÓRIO — string aleatória, mínimo 32 caracteres
# Gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_ISSO_openssl_rand_hex_32

# ── Administração ─────────────────────────────────────────────────────────────

# ★ OBRIGATÓRIO — chave para criar tenants via API (POST /admin/tenants)
# Gere com: openssl rand -hex 24
SUPER_ADMIN_KEY=TROQUE_ISSO_openssl_rand_hex_24

# ── Multi-tenancy ─────────────────────────────────────────────────────────────

# Slug do tenant padrão quando não há subdomínio
DEFAULT_TENANT=piloto

# true → usa subdomínio para identificar o tenant (ex: loja1.seudominio.com)
# false → todas as requisições usam DEFAULT_TENANT
USE_SUBDOMAIN_TENANT=false

# ── Ambiente da aplicação ─────────────────────────────────────────────────────

# production | development
KTOR_ENV=production

# Origem permitida para requisições CORS (domínio do frontend sem barra final).
# Deixe em branco em desenvolvimento local — aceita qualquer origem.
# Em produção, defina para o domínio exato do frontend:
#   ALLOWED_ORIGIN=app.seudominio.com.br
ALLOWED_ORIGIN=

# ── NF-e / SEFAZ ─────────────────────────────────────────────────────────────

# homologacao | producao
NFE_AMBIENTE=homologacao

# ★ OBRIGATÓRIO se NFE_AMBIENTE=producao
# Proteção contra emissão acidental em produção — deve ser "true" explícito
NFE_PRODUCAO_CONFIRMADO=false

# Diretório onde os XMLs das NF-e autorizadas são salvos
# (mapeado como volume Docker em /var/data/nfe/xml)
# NFE_XML_DIR=/var/data/nfe/xml

# ── Certificado ICP-Brasil (SEFAZ) ────────────────────────────────────────────
# Necessário apenas em NFE_AMBIENTE=producao para validar a cadeia TLS da SEFAZ.
# Em homologação, o trust-all é usado automaticamente.
#
# Como gerar o truststore: ver IcpBrasilTrustManager.kt (instrução com keytool)
# ICP_BRASIL_TRUSTSTORE_PATH=/certs/icp-brasil.jks
# ICP_BRASIL_TRUSTSTORE_PASSWORD=changeit

# ── NTP (validação de horário na emissão de NF-e) ────────────────────────────
# NFE_NTP_HOST=pool.ntp.org
# NFE_NTP_TOLERANCIA_S=120

# ── Frontend ──────────────────────────────────────────────────────────────────

# ★ OBRIGATÓRIO em produção — URL pública do backend (sem barra final)
# Exemplos:
#   Domínio próprio: https://api.seudominio.com.br
#   Railway:         https://madex-backend.up.railway.app
#   Mesmo host:      http://localhost:8080
VITE_API_URL=http://localhost:8080

# ── SMS via Redbot (cobranças/notificações) — opcional ───────────────────────
# REDBOT_URL=https://api.redbot.chat/v1/messages
# REDBOT_KEY=sua_chave_redbot
